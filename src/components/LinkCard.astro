---
import { Image } from "astro:assets";
import { ExternalLinkIcon } from "../icons";
import RenderIcon from "./RenderIcon.astro";

// Menambahkan penerima data 'price' dan 'buttonText'
const { label, description, url, icon, cover, price, buttonText } = Astro.props;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="group relative flex items-center justify-between p-4 mb-4 rounded-2xl bg-white/5 backdrop-blur-md border border-white/10 hover:bg-white/10 hover:border-violet-400/50 hover:shadow-[0_0_15px_rgba(139,92,246,0.3)] transition-all overflow-hidden"
>
  <div class="flex items-center gap-4 w-full relative z-10">
    {/* Menampilkan Gambar/Cover Produk jika ada */}
    {
      cover ? (
        <div class="flex-shrink-0">
          <Image
            src={cover}
            alt={label}
            width={64}
            height={64}
            class="w-16 h-16 rounded-xl object-cover shadow-md border border-white/10 group-hover:scale-105 transition-transform"
          />
        </div>
      ) : icon ? (
        <div class="flex-shrink-0 w-16 h-16 flex items-center justify-center bg-white/5 rounded-xl border border-white/10 group-hover:scale-105 transition-transform">
          <RenderIcon icon={icon} class="w-8 h-8 text-white/70" />
        </div>
      ) : null
    }

    {/* Info Produk / Link */}
    <div class="flex flex-col flex-1 min-w-0">
      <h3 class="text-white font-bold text-lg truncate group-hover:text-violet-300 transition-colors">
        {label}
      </h3>
      
      {description && (
        <p class="text-white/60 text-sm leading-tight mt-1 line-clamp-2">
          {description}
        </p>
      )}

      {/* TAMPILAN HARGA (Hanya muncul kalau diisi di site.json) */}
      {price && (
        <div class="mt-2 text-cyan-300 font-extrabold tracking-wide">
          {price}
        </div>
      )}

      {/* TOMBOL BELI WA (Hanya muncul kalau diisi di site.json) */}
      {buttonText && (
        <div class="mt-2 inline-block">
          <span class="bg-green-500/20 text-green-400 border border-green-500/50 px-3 py-1 rounded-lg text-xs font-bold uppercase tracking-wider flex items-center gap-1 w-max group-hover:bg-green-500 group-hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21" /><path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1" /></svg>
            {buttonText}
          </span>
        </div>
      )}
    </div>
  </div>

  <div class="flex-shrink-0 ml-2 opacity-50 group-hover:opacity-100 group-hover:translate-x-1 transition-all z-10">
    <ExternalLinkIcon class="w-5 h-5 text-white" />
  </div>
</a>
