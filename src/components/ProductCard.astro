---
interface Props {
  label: string;
  url: string;
  description?: string;
  cover?: string;
  price?: string;
  buttonText?: string;
  shopeeUrl?: string;
  id: string;
}

const { label, description, url, cover, price, buttonText, shopeeUrl, id } = Astro.props;
const dialogId = `dialog-${id}`;
---

<!-- Trigger Card -->
<div 
  class="group cursor-pointer flex flex-col p-3 rounded-2xl bg-white/5 backdrop-blur-md border border-white/10 hover:bg-white/10 hover:border-violet-400/50 hover:shadow-[0_0_15px_rgba(139,92,246,0.3)] transition-all overflow-hidden"
  onclick={`document.getElementById('${dialogId}').showModal()`}
>
  <div class="w-full aspect-[4/3] rounded-xl overflow-hidden mb-3 relative bg-black/20 border border-white/10">
    {cover ? (
      <img src={cover} alt={label} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/30"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
      </div>
    )}
  </div>
  <h3 class="text-white font-bold text-sm line-clamp-2 leading-tight group-hover:text-violet-300 transition-colors text-center">
    {label}
  </h3>
  {price && (
    <p class="text-cyan-300 font-bold text-xs mt-2 text-center">{price}</p>
  )}
</div>

<!-- Modal Dialog -->
<dialog id={dialogId} class="bg-transparent m-auto p-0 border-none w-[90%] max-w-sm backdrop:bg-black/80 backdrop:backdrop-blur-sm fixed inset-0 z-50">
  <div class="bg-gray-900 border border-white/20 rounded-3xl overflow-hidden flex flex-col relative text-left shadow-2xl open:animate-in open:zoom-in-95 open:duration-300">
    
    <!-- Close Button -->
    <button 
      onclick={`event.stopPropagation(); document.getElementById('${dialogId}').close()`}
      class="absolute top-3 right-3 z-20 w-8 h-8 flex items-center justify-center bg-black/50 text-white rounded-full hover:bg-black/80 transition-colors border border-white/10"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
    
    <!-- Image Header -->
    <div class="w-full h-56 relative bg-black/50">
      {cover ? (
        <img src={cover} alt={label} class="w-full h-full object-cover" />
      ) : (
        <div class="w-full h-full flex items-center justify-center">
           <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/30"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
        </div>
      )}
      <!-- Gradient overlay for text contrast -->
      <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/40 to-transparent"></div>
    </div>
    
    <!-- Content Section -->
    <div class="p-5 -mt-10 relative z-10 flex flex-col gap-3">
      <h3 class="text-white font-bold text-xl leading-tight">
        {label}
      </h3>
      
      {price && (
        <div class="text-cyan-400 font-extrabold text-lg">
          {price}
        </div>
      )}

      {description && (
        <p class="text-white/70 text-sm leading-relaxed mt-1">
          {description}
        </p>
      )}

      <div class="mt-4 pt-4 border-t border-white/10 flex flex-col gap-3">
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 bg-[#25D366] hover:bg-[#20bd5a] text-white px-5 py-3 rounded-xl font-bold transition-all shadow-lg shadow-[#25D366]/30 hover:scale-105 w-full justify-center"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
          {buttonText || "Beli Sekarang"}
        </a>

        {/* Tombol Shopee */}
        {shopeeUrl ? (
          <a
            href={shopeeUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 bg-[#ee4d2d] hover:bg-[#d73f20] text-white px-5 py-3 rounded-xl font-bold transition-all shadow-lg shadow-[#ee4d2d]/30 hover:scale-105 w-full justify-center"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
              <path d="M3 6h18"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            Beli di Shopee
          </a>
        ) : (
          <button
            type="button"
            onclick="alert('Maaf, produk tidak tersedia di Shopee.')"
            class="flex items-center gap-2 bg-[#ee4d2d] hover:bg-[#d73f20] text-white px-5 py-3 rounded-xl font-bold transition-all shadow-lg shadow-[#ee4d2d]/30 hover:scale-105 w-full justify-center"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
              <path d="M3 6h18"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            Beli di Shopee
          </button>
        )}
      </div>
    </div>
  </div>
</dialog>

